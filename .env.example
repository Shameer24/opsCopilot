# ── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
OPENAI_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose default (postgres service in compose):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/opscopilot
#
# Supabase (for free cloud deploy — use "Session mode" pooler URL):
# DATABASE_URL=postgresql+psycopg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── LLM provider ──────────────────────────────────────────────────────────────
# "openai"  → uses OPENAI_API_KEY + CHAT_MODEL
# "ollama"  → uses OLLAMA_BASE_URL + OLLAMA_MODEL (local/self-hosted)
LLM_PROVIDER=openai
CHAT_MODEL=gpt-4.1-mini

# Ollama (only if LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1

# ── Embeddings ────────────────────────────────────────────────────────────────
# "local"   → sentence-transformers runs in the backend container (default, no cost)
# "openai"  → uses OPENAI_API_KEY + EMBEDDING_MODEL
EMBEDDINGS_PROVIDER=local
# EMBEDDING_MODEL=text-embedding-3-small

# ── CORS (set to your frontend URL in production) ─────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# TOP_K=6
# MIN_SCORE=0.10
# MAX_UPLOAD_MB=25
